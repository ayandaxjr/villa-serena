# ============================================================
# Villa Serena Admin Panel — Environment Variables
# Copy this to .env.local and fill in real values.
# ============================================================

# ── Supabase (same project as the public website) ──────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-jwt-key-here
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-jwt-key-here

# ── Stripe (Jelmer's Stripe account) ──────────────────────
# Get this from: dashboard.stripe.com → Developers → API Keys → Secret key
# Use the LIVE key for production, TEST key while building
STRIPE_SECRET_KEY=replace_with_your_stripe_secret_key

# ── Public website (for forwarding email notifications) ───
MAIN_SITE_URL=https://www.villaserena.nl
NEXT_PUBLIC_MAIN_SITE_URL=https://www.villaserena.nl

# ── Security ───────────────────────────────────────────────
# Generate a random string: openssl rand -hex 32
ADMIN_SECRET=replace-with-a-long-random-secret-string
