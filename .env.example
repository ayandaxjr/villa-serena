# ============================================================
# Villa Serena — Public Website Environment Variables
# Copy this file to .env.local and fill in your values.
# ============================================================

# Supabase — get these from your Supabase project settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Resend — get from resend.com/api-keys
# Verify villaserena.nl domain in Resend before going live.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Email — inquiries are delivered TO this inbox
CONTACT_EMAIL=info@villa-serena.nl
# FROM must use a verified domain in Resend (or onboarding@resend.dev for testing)
FROM_EMAIL=Villa Serena <notifications@villaserena.nl>

# Admin panel URL (used in email links)
NEXT_PUBLIC_ADMIN_URL=https://admin-villas-arena.vercel.app

# Contact details shown in approval emails
CONTACT_PHONE=+31 6 44833330

# Legacy fallback — can be removed once DB is set up
# BOOKED_PERIODS=[{"start":"2026-07-01","end":"2026-07-14","label":"Booked"}]
